{
  "name": "openanchor-pwa",
  "version": "1.0.0",
  "description": "OpenAnchor Progressive Web App with comprehensive tests",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && tsc --noEmit -p src/service-worker/tsconfig.json && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "serve": "vite preview --port 8080",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "node ./scripts/run-e2e-coverage.mjs",
    "test:e2e:coverage:report": "node ./scripts/generate-e2e-coverage-report.mjs",
    "test:e2e:coverage:comment": "node ./scripts/generate-e2e-coverage-comment.mjs",
    "test:e2e:dev": "E2E_DEV=true playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report e2e-results/html"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/leaflet": "^1.9.21",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "esbuild": "^0.27.7",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.8.9",
    "http-server": "^14.1.1",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-instrument": "^6.0.3",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-istanbul": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "dompurify": "^3.3.3",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "lucide": "^1.7.0",
    "lucide-react": "^1.7.0",
    "lz-string": "^1.5.0",
    "marked": "^17.0.5",
    "pdfjs-dist": "^5.6.205",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}

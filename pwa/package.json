{
  "name": "openanchor-pwa",
  "version": "1.0.0",
  "description": "OpenAnchor Progressive Web App with comprehensive tests",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "dev": "http-server . -p 8080",
    "serve": "http-server . -p 8080",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report e2e-results/html"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "happy-dom": "^20.0.0",
    "http-server": "^14.1.1",
    "vitest": "^4.1.0"
  }
}
